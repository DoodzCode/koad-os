# KoadOS — Unified Environment Namespace (Hierarchical Overrides)
# Pattern: KOADOS_[TIER]_[CONTEXT]_[KEY]
# Tiers: MAIN (Citadel), STATION (Project Hub), OUTPOST (Individual Project)
# Context: Optional (Name of Station or Outpost)

# --- Infrastructure ---
KOADOS_HOME=~/.koad-os
KOADOS_URL_REDIS=redis://localhost:6379
KOADOS_URL_QDRANT=http://localhost:6333
KOADOS_AUTH_REDIS=

# --- Main (Citadel / Fallback) ---
KOADOS_MAIN_GITHUB_PAT=
KOADOS_MAIN_GITHUB_USER=
KOADOS_MAIN_GITHUB_EMAIL=
KOADOS_MAIN_EMAIL_PRIMARY=
KOADOS_MAIN_NOTION_TOKEN=

# --- Station Overrides (Example: SLE) ---
KOADOS_STATION_SLE_GITHUB_PAT=
KOADOS_STATION_SLE_GITHUB_USER=
KOADOS_STATION_SLE_GITHUB_EMAIL=
KOADOS_STATION_SLE_AIRTABLE_TOKEN=
KOADOS_STATION_SLE_STRIPE_PUB_KEY=
KOADOS_STATION_SLE_STRIPE_SEC_KEY=

# --- Station Overrides (Example: DND) ---
# KOADOS_STATION_DND_GITHUB_PAT=DND_GITHUB_PAT

# --- Integration Access ---
# (Generic placeholders used by Citadel subsystems)
KOADOS_PAT_NOTION_MAIN=
KOADOS_PAT_GITHUB_ADMIN=

# --- Claude Desktop Agent (Optional) ---
# Set during koad-init.sh or manually. Used by docker/rook/rook-up.sh.
KOADOS_CLAUDE_AGENT_NAME=

# --- Runtime Options ---
KOADOS_URL_LLM_LOCAL=http://localhost:11434
KOADOS_CACHE_THRESHOLD=0.92
